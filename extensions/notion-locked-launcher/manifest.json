{
  "manifest_version": 3,
  "name": "Notion Locked Launcher",
  "version": "1.0.0",
  "description": "Lock a Notion tab as a launcher: nav links open in new tabs; the locked tab stays put.",
  "browser_specific_settings": {
    "gecko": {
      "id": "notion-locked-launcher@quiet-layer",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "permissions": ["tabs", "menus"],
  "host_permissions": [
    "https://www.notion.com/*",
    "https://notion.com/*",
    "https://*.notion.com/*",
    "https://www.notion.so/*",
    "https://notion.so/*",
    "https://*.notion.so/*",
    "https://www.notion.site/*",
    "https://notion.site/*",
    "https://*.notion.site/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    },
    "default_title": "Notion Locked Launcher — lock this tab"
  },
  "commands": {
    "toggle-lock": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Lock/unlock Notion tab as launcher"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.notion.com/*",
        "https://notion.com/*",
        "https://*.notion.com/*",
        "https://www.notion.so/*",
        "https://notion.so/*",
        "https://*.notion.so/*",
        "https://www.notion.site/*",
        "https://notion.site/*",
        "https://*.notion.site/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
